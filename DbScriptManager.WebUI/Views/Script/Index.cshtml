@model List<DbScriptManager.Application.DTOs.ScriptDto>

@{
    ViewData["Title"] = "Scriptler";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isAdmin = User.IsInRole("Admin");
    var activeFilterCount = (int)(ViewBag.ActiveFilterCount ?? 0);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Scriptler</h1>
        <p class="page-header-subtitle">Tüm SQL scriptleri</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i>
        Yeni Script
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle-fill"></i>
        @TempData["ErrorMessage"]
    </div>
}

<!-- FİLTRE PANELİ -->
<div class="card mb-3">
    <div class="card-header" style="cursor:pointer;" onclick="toggleFilter()">
        <span class="card-header-title">
            <i class="bi bi-funnel me-2" style="color: var(--accent);"></i>
            Filtrele
            @if (activeFilterCount > 0)
            {
                <span style="margin-left:0.5rem; background:var(--accent); color:white; border-radius:9999px; font-size:0.7rem; padding:0.1rem 0.5rem; font-weight:600;">
                    @activeFilterCount aktif
                </span>
            }
        </span>
        <i class="bi bi-chevron-down" id="filterChevron" style="transition: transform 0.2s;"></i>
    </div>
    <div id="filterPanel" style="display: @(activeFilterCount > 0 ? "block" : "none");">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <!-- Arama -->
                    <div class="col-md-4">
                        <label class="form-label">Arama</label>
                        <div style="position:relative;">
                            <i class="bi bi-search" style="position:absolute; left:0.75rem; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:0.8rem;"></i>
                            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                                   class="form-control" style="padding-left:2rem;"
                                   placeholder="Script adı veya developer..." />
                        </div>
                    </div>

                    <!-- Versiyon -->
                    <div class="col-md-2">
                        <label class="form-label">Versiyon</label>
                        <select name="versionId" asp-items="ViewBag.Versions" class="form-control form-select">
                            <option value="">Tümü</option>
                        </select>
                    </div>

                    <!-- Database -->
                    <div class="col-md-2">
                        <label class="form-label">Database</label>
                        <select name="databaseConfigId" asp-items="ViewBag.DatabaseConfigs" class="form-control form-select">
                            <option value="">Tümü</option>
                        </select>
                    </div>

                    <!-- Tip -->
                    <div class="col-md-2">
                        <label class="form-label">Tip</label>
                        <select name="scriptType" class="form-control form-select">
                            <option value="">Tümü</option>
                            <option value="Script"   selected="@(ViewBag.SelectedType == "Script"   ? "selected" : null)">Script</option>
                            <option value="Rollback" selected="@(ViewBag.SelectedType == "Rollback" ? "selected" : null)">Rollback</option>
                            <option value="Cache"    selected="@(ViewBag.SelectedType == "Cache"    ? "selected" : null)">Cache</option>
                        </select>
                    </div>

                    <!-- Tarih aralığı -->
                    <div class="col-md-1">
                        <label class="form-label">Başlangıç</label>
                        <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label">Bitiş</label>
                        <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control" />
                    </div>
                </div>

                <div style="display:flex; gap:0.5rem; margin-top:1rem;">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-search"></i> Filtrele
                    </button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                        <i class="bi bi-x-lg"></i> Temizle
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- TABLO -->
<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-file-earmark-code me-2" style="color: var(--accent);"></i>
            Kayıtlı Scriptler
            @if (Model != null)
            {
                <span class="badge-count badge-primary" style="margin-left:0.5rem;">@Model.Count</span>
            }
        </span>
    </div>

    <div class="card-body" style="padding: 0;">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Script Adı</th>
                            <th style="width:110px;">Tip</th>
                            <th>Versiyon</th>
                            <th>Database</th>
                            <th>Developer</th>
                            <th>Tarih</th>
                            <th style="text-align:right; width:120px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var script in Model)
                        {
                            <tr>
                                <td style="color:var(--text-muted); font-size:0.75rem; font-weight:500;">#@script.Id</td>
                                <td style="font-weight:600; color:var(--text-primary);">
                                    <i class="bi bi-file-code" style="color:var(--accent); margin-right:0.375rem;"></i>
                                    @script.ScriptName
                                </td>
                                <td>
                                    @{
                                        var (typeIcon, typeColor, typeBg) = script.ScriptType switch {
                                            "Cache"    => ("bi-lightning-charge-fill", "#ef4444", "rgba(239,68,68,0.1)"),
                                            "Rollback" => ("bi-arrow-counterclockwise", "#f59e0b", "rgba(245,158,11,0.1)"),
                                            _          => ("bi-file-earmark-code", "#6366f1", "rgba(99,102,241,0.1)")
                                        };
                                    }
                                    <span style="display:inline-flex; align-items:center; gap:0.3rem; padding:0.2rem 0.55rem; border-radius:9999px; font-size:0.7rem; font-weight:600; background:@typeBg; color:@typeColor;">
                                        <i class="bi @typeIcon"></i>
                                        @script.ScriptType
                                    </span>
                                </td>
                                <td><span class="badge-version">@script.VersionName</span></td>
                                <td>
                                    <span style="font-size:0.8rem; color:var(--text-secondary);">
                                        <i class="bi bi-database" style="margin-right:0.25rem; color:#10b981;"></i>
                                        @(string.IsNullOrEmpty(script.DatabaseName) ? "-" : script.DatabaseName)
                                    </span>
                                </td>
                                <td style="color:var(--text-secondary); font-size:0.8rem;">@script.DeveloperName</td>
                                <td>
                                    <span style="color:var(--text-muted); font-size:0.75rem;">
                                        <i class="bi bi-calendar3" style="margin-right:0.25rem;"></i>
                                        @script.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                    </span>
                                </td>
                                <td style="text-align:right;">
                                    <div style="display:flex; gap:0.375rem; justify-content:flex-end;">
                                        <a asp-action="Detail" asp-route-id="@script.Id"
                                           class="btn btn-ghost btn-sm" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isAdmin || script.CreatedByUserId == currentUserId)
                                        {
                                            <form asp-action="Delete" asp-route-id="@script.Id" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Bu script silinsin mi?')" title="Sil">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-file-earmark-code" style="font-size:1.5rem; color:var(--text-muted);"></i>
                </div>
                <div class="empty-state-title">Script bulunamadı</div>
                <p class="empty-state-text">Filtreyi değiştirin veya yeni script oluşturun.</p>
                <a asp-action="Create" class="btn btn-primary" style="margin-top:0.75rem;">
                    <i class="bi bi-plus-lg"></i> Yeni Script Oluştur
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function toggleFilter() {
        const panel   = document.getElementById('filterPanel');
        const chevron = document.getElementById('filterChevron');
        const open    = panel.style.display === 'block';
        panel.style.display  = open ? 'none' : 'block';
        chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
    }

    // Aktif filtre varsa chevron'u döndür
    document.addEventListener('DOMContentLoaded', () => {
        if (@activeFilterCount > 0)
            document.getElementById('filterChevron').style.transform = 'rotate(180deg)';
    });
</script>
}