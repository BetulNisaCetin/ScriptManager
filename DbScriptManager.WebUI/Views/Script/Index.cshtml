@model List<DbScriptManager.Application.DTOs.ScriptDto>

@{
    ViewData["Title"] = "Scriptler";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Scriptler</h1>
        <p class="page-header-subtitle">Tüm SQL scriptleri</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i>
        Yeni Script
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle-fill"></i>
        @TempData["ErrorMessage"]
    </div>
}

<div class="card">
    <div class="card-header">
        <span class="card-header-title">
            <i class="bi bi-file-earmark-code me-2" style="color: var(--accent);"></i>
            Kayıtlı Scriptler
            @if (Model != null)
            {
                <span class="badge-count badge-primary" style="margin-left:0.5rem;">@Model.Count</span>
            }
        </span>
    </div>

    <div class="card-body" style="padding: 0;">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Script Adı</th>
                            <th style="width:110px;">Tip</th>
                            <th>Versiyon</th>
                            <th>Developer</th>
                            <th>Oluşturulma Tarihi</th>
                            <th style="text-align:right; width:120px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var script in Model)
                        {
                            <tr>
                                <td style="color: var(--text-muted); font-size:0.75rem; font-weight:500;">
                                    #@script.Id
                                </td>
                                <td style="font-weight:600; color: var(--text-primary);">
                                    <i class="bi bi-file-code" style="color: var(--accent); margin-right:0.375rem;"></i>
                                    @script.ScriptName
                                </td>
                                <td>
                                    @{
                                        var (typeIcon, typeColor, typeBg) = script.ScriptType switch {
                                            "Cache"    => ("bi-lightning-charge-fill", "#ef4444", "rgba(239,68,68,0.1)"),
                                            "Rollback" => ("bi-arrow-counterclockwise",  "#f59e0b", "rgba(245,158,11,0.1)"),
                                            _          => ("bi-file-earmark-code",        "#6366f1", "rgba(99,102,241,0.1)")
                                        };
                                    }
                                    <span style="display:inline-flex; align-items:center; gap:0.3rem; padding:0.2rem 0.55rem; border-radius:9999px; font-size:0.7rem; font-weight:600; background:@typeBg; color:@typeColor;">
                                        <i class="bi @typeIcon"></i>
                                        @script.ScriptType
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-version">@script.VersionName</span>
                                </td>
                                <td style="color: var(--text-secondary); font-size:0.8rem;">
                                    @script.DeveloperName
                                </td>
                                <td>
                                    <span style="color: var(--text-muted); font-size:0.75rem;">
                                        <i class="bi bi-calendar3" style="margin-right:0.25rem;"></i>
                                        @script.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                    </span>
                                </td>
                                <td style="text-align:right;">
                                    <div style="display:flex; gap:0.375rem; justify-content:flex-end;">
                                        <a asp-action="Detail" asp-route-id="@script.Id"
                                           class="btn btn-ghost btn-sm" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isAdmin || script.CreatedByUserId == currentUserId)
                                        {
                                            <form asp-action="Delete" asp-route-id="@script.Id" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Bu script silinsin mi?')" title="Sil">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="bi bi-file-earmark-code" style="font-size:1.5rem; color: var(--text-muted);"></i>
                </div>
                <div class="empty-state-title">Henüz script yok</div>
                <p class="empty-state-text">İlk scripti oluşturmak için butona tıklayın.</p>
                <a asp-action="Create" class="btn btn-primary" style="margin-top:0.75rem;">
                    <i class="bi bi-plus-lg"></i>
                    Yeni Script Oluştur
                </a>
            </div>
        }
    </div>
</div>
